{
                      "navigationFallback": {
                        "rewrite": "/index.html",
                        "exclude": ["/static/media/*", "/static/css/*", "/static/js/*", "*.png", "*.jpg", "*.jpeg", "*.gif", "*.svg", "*.ico", "*.json", "*.txt", "*.webmanifest", "*.woff", "*.woff2"]
                      },
                      "mimeTypes": {
                        ".json": "application/json",
                        ".webmanifest": "application/manifest+json",
                        ".woff2": "font/woff2"
                      },
                      "responseOverrides": {
                        "404": {
                          "rewrite": "/index.html",
                          "statusCode": 200
                        }
                      }
                    }